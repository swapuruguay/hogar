<div class="container">
  <h1>{{titulo}}</h1>
  <p>&nbsp;</p>
  {{#if mensaje}}
    <div class="alert alert-success">{{mensaje}}</div>
  {{/if}}
  {{#if error}}
    <div class="alert alert-danger">{{error}}</div>
  {{/if}}
  <p>
    <a href="/contable/conceptos/nuevo" class="btn btn-primary">
      <i class="fa fa-plus"></i> Nuevo concepto
    </a>
  </p>
  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th class="text-center">Id</th>
        <th>Concepto</th>
        <th class="text-center">Lado</th>
        <th class="text-center">Acciones</th>
      </tr>
    </thead>
    <tbody>
      {{#each tipos}}
      <tr>
        <td class="text-center">{{id_tipo}}</td>
        <td>{{tipo}}</td>
        <td class="text-center">{{lado_txt}}</td>
        <td class="text-center">
          <a href="/contable/conceptos/editar/{{id_tipo}}" title="Editar">
            <i class="fa fa-pencil"></i>
          </a>
          &nbsp;&nbsp;
          <a href="/contable/conceptos/eliminar/{{id_tipo}}" title="Eliminar" onclick="return confirm('¿Eliminar concepto?')">
            <i class="fa fa-trash"></i>
          </a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
