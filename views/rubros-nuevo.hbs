<div class="container">
  <h1>{{titulo}}</h1>
  <p>&nbsp;</p>
  <form class="form-horizontal" method="post" action="/contable/conceptos/guardar">
    <div class="form-group">
      <label for="id_tipo" class="col-sm-2 control-label">Id</label>
      <div class="col-sm-2">
        <input type="text" class="form-control text-center" id="id_tipo" name="id_tipo" value="{{concepto.id_tipo}}" readonly>
      </div>
    </div>
    <div class="form-group">
      <label for="tipo" class="col-sm-2 control-label">Concepto</label>
      <div class="col-sm-5">
        <input type="text" class="form-control" id="tipo" name="tipo" value="{{concepto.tipo}}" required>
      </div>
    </div>
    <div class="form-group">
      <label for="lado" class="col-sm-2 control-label">Lado</label>
      <div class="col-sm-3">
        <select class="form-control" id="lado" name="lado" required>
          <option value="D" {{concepto.ladoD}}>Debe (D)</option>
          <option value="H" {{concepto.ladoH}}>Haber (H)</option>
        </select>
      </div>
    </div>
    <div class="form-group">
      <div class="col-sm-offset-2 col-sm-10">
        <button type="submit" class="btn btn-success">
          <i class="fa fa-floppy-o"></i> Guardar
        </button>
        <a href="/contable/conceptos" class="btn btn-default">Cancelar</a>
      </div>
    </div>
  </form>
</div>
