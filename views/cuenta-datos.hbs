<div class="row">
  <div class="col-md-6">
    <h3>Mis datos</h3>
    {{#if error}}
      <div class="alert alert-danger" role="alert">{{error.[0]}}</div>
    {{/if}}
    {{#if ok}}
      <div class="alert alert-success" role="alert">{{ok.[0]}}</div>
    {{/if}}
    <form action="/cuenta/datos" method="post" class="form-horizontal">
      <div class="form-group">
        <label for="username" class="col-sm-4 control-label">Usuario</label>
        <div class="col-sm-8">
          <input type="text" id="username" name="username" class="form-control" value="{{user.username}}" required>
        </div>
      </div>
      <div class="form-group">
        <label for="nombre" class="col-sm-4 control-label">Nombre</label>
        <div class="col-sm-8">
          <input type="text" id="nombre" name="nombre" class="form-control" value="{{user.nombre}}" required>
        </div>
      </div>
      <div class="form-group">
        <label for="apellido" class="col-sm-4 control-label">Apellido</label>
        <div class="col-sm-8">
          <input type="text" id="apellido" name="apellido" class="form-control" value="{{user.apellido}}" required>
        </div>
      </div>
      <div class="form-group">
        <div class="col-sm-offset-4 col-sm-8">
          <button type="submit" class="btn btn-primary">Guardar</button>
        </div>
      </div>
    </form>
  </div>
</div>
